						{
							"listen": "test",
							"script": {
								"exec": [
									"// Parse the JSON response",
									"const jsonData = pm.response.json();",
									"",
									"// Test that the response status is 201",
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"// Test that the token field exists and is a non-empty string",
									"pm.test(\"Token exists and is a non-empty string\", function () {",
									"    pm.expect(jsonData).to.have.property(\"token\");",
									"    pm.expect(jsonData.token).to.be.a(\"string\").and.not.empty;",
									"});",
									"",
									"// Save the token to an environment variable",
									"pm.environment.set(\"authToken\", \"Bearer \" + jsonData.token);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
