		{
			"name": "rate limit testing",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (pm.info.iteration === 0) {",
									"    const keys = [",
									"        'rl_total_requests',",
									"        'rl_success_2xx',",
									"        'rl_429_count',",
									"        'rl_4xx_other',",
									"        'rl_5xx',",
									"        'rl_first_429_iteration',",
									"        'rl_first_429_time_ms',",
									"        'rl_last_response_info'",
									"    ];",
									"    keys.forEach(k => pm.environment.unset(k));",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"// --- Basic status check ---",
									"pm.test(\"Status is 2xx or 429\", function () {",
									"    pm.expect([200, 201, 204, 400, 401, 403, 429]).to.include(pm.response.code);",
									"});",
									"",
									"// --- Capture response metadata per iteration ---",
									"const iteration = pm.info.iteration;",
									"const statusCode = pm.response.code;",
									"const responseTime = pm.response.responseTime;",
									"const retryAfterHeader = pm.response.headers.get('Retry-After');",
									"",
									"// Try to parse JSON safely",
									"let parsedBody = {};",
									"try {",
									"    parsedBody = pm.response.json();",
									"} catch (e) {",
									"    parsedBody = { parseError: true };",
									"}",
									"",
									"// Keep simple counters in environment",
									"function incCounter(name) {",
									"    const current = Number(pm.environment.get(name) || 0);",
									"    pm.environment.set(name, current + 1);",
									"}",
									"",
									"incCounter('rl_total_requests');",
									"",
									"if (statusCode === 200) {",
									"    incCounter('rl_success_2xx');",
									"} else if (statusCode === 429) {",
									"    incCounter('rl_429_count');",
									"} else if (statusCode >= 400 && statusCode < 500) {",
									"    incCounter('rl_4xx_other');",
									"} else if (statusCode >= 500) {",
									"    incCounter('rl_5xx');",
									"}",
									"",
									"// Track the first time we see a 429",
									"if (statusCode === 429 && !pm.environment.get('rl_first_429_iteration')) {",
									"    pm.environment.set('rl_first_429_iteration', String(iteration));",
									"    pm.environment.set('rl_first_429_time_ms', String(responseTime));",
									"}",
									"",
									"// Keep minimal last-response info so you can inspect later",
									"const lastInfo = {",
									"    iteration,",
									"    statusCode,",
									"    responseTime,",
									"    retryAfterHeader: retryAfterHeader || null,",
									"    timestamp: new Date().toISOString()",
									"};",
									"pm.environment.set('rl_last_response_info', JSON.stringify(lastInfo));",
									"",
									"// Optional: fail the run after too many 429s",
									"const max429 = Number(pm.environment.get('rl_max_429_before_fail') || 0);",
									"if (max429 > 0) {",
									"    const current429 = Number(pm.environment.get('rl_429_count') || 0);",
									"    pm.test(\"Rate limit: 429 count not exceeded threshold\", function () {",
									"        pm.expect(current429).to.be.below(max429);",
									"    });",
									"}",
									"",
									"// Optional console logging if you want to see streaming info",
									"console.log('[RL]', 'iter:', iteration, 'status:', statusCode, 'rt:', responseTime, 'Retry-After:', retryAfterHeader);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"email\":\"{{test_email}}\",\"password\":\"{{test_password}}\"}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/auth/login?lan=ja",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							],
							"query": [
								{
									"key": "lan",
									"value": "ja"
								}
							]
						}
					},
					"response": []
				}
			]
		},
