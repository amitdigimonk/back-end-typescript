<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= appName %></title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol';
            margin: 0;
            padding: 8vh 5vw;
            background-color: #fafafa;
            color: #1a1a1a;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }
        .container {
            max-width: 760px;
            margin: 0 auto;
        }
        .header {
            margin-bottom: 4rem;
        }
        h1 {
            font-size: 2rem;
            font-weight: 600;
            letter-spacing: -0.02em;
            margin: 0 0 0.5rem 0;
            color: #111;
        }
        p {
            font-size: 1rem;
            color: #666;
            margin: 0;
        }
        .status {
            display: inline-flex;
            align-items: center;
            margin-top: 1rem;
            font-size: 0.85rem;
            color: #555;
            padding: 0.3rem 0;
        }
        .status-dot {
            width: 6px;
            height: 6px;
            background-color: #10b981;
            border-radius: 50%;
            margin-right: 8px;
        }
        .docs-section {
            margin-bottom: 2.5rem;
        }
        .docs-section h2 {
            font-size: 1.1rem;
            font-weight: 500;
            border-bottom: 1px solid #eaeaea;
            padding-bottom: 0.5rem;
            margin-bottom: 1rem;
            text-transform: capitalize;
            color: #333;
        }
        .endpoint {
            display: flex;
            align-items: baseline;
            padding: 0.5rem 0;
            border-bottom: 1px solid #f5f5f5;
        }
        .endpoint:last-child {
            border-bottom: none;
        }
        .method {
            font-weight: 600;
            font-size: 0.75rem;
            margin-right: 1.5rem;
            min-width: 50px;
            letter-spacing: 0.05em;
        }
        .method.GET { color: #059669; }
        .method.POST { color: #2563eb; }
        .method.PUT { color: #d97706; }
        .method.PATCH { color: #7c3aed; }
        .method.DELETE { color: #dc2626; }
        
        .path {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.9rem;
            color: #444;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><%= appName %></h1>
            <p>API Server is running</p>
            <div class="status">
                <div class="status-dot"></div>
                Uptime: <%= uptime %>
            </div>
        </div>

        <% if (endpoints && Object.keys(endpoints).length > 0) { %>
            <% Object.keys(endpoints).forEach(function(category) { %>
                <div class="docs-section">
                    <h2><%= category === 'general' ? 'General' : category %></h2>
                    <% endpoints[category].forEach(function(endpoint) { %>
                        <% endpoint.methods.forEach(function(method) { %>
                            <div class="endpoint">
                                <span class="method <%= method %>"><%= method %></span>
                                <span class="path"><%= endpoint.path %></span>
                            </div>
                        <% }); %>
                    <% }); %>
                </div>
            <% }); %>
        <% } %>
    </div>
</body>
</html>
