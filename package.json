{
  "name": "backend",
  "version": "1.0.0",
  "description": "a typescript node backend",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && copyfiles -u 1 \"src/locales/**/*.json\" \"src/templates/**/*.ejs\" \"src/view/**/*.ejs\" \"src/public/**/*\" dist/",
    "build:prod": "BUILD_ENV=prod npm run build",
    "postbuild": "node scripts/postbuild.js",
    "start": "node dist/index.js",
    "seed": "ts-node src/seeders/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-list-endpoints": "^7.1.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.1.0",
    "i18next": "^25.7.4",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.4",
    "multer": "^2.0.2",
    "serve-favicon": "^2.5.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-list-endpoints": "^6.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.9",
    "@types/serve-favicon": "^2.5.7",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
